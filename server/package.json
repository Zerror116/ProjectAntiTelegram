{
  "name": "projectphoenix-server",
  "version": "1.0.0",
  "description": "Backend for ProjectPhoenix (minimal Express + Postgres API)",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "worker": "node src/worker.js",
    "address-gateway": "node scripts/address-provider-gateway.js",
    "lint": "eslint src scripts --ext .js --max-warnings=0",
    "test:critical": "node scripts/critical-integration.js",
    "test:critical:admin": "E2E_STRICT_ADMIN=1 node scripts/critical-integration.js",
    "test:phone-access:e2e": "node scripts/e2e-phone-access-flow.js",
    "test:subscription-guard:e2e": "node scripts/e2e-subscription-guard-flow.js",
    "test:address-provider:smoke": "node scripts/address-provider-smoke.js --simulate-unavailable",
    "test:order-pipeline:e2e": "node scripts/e2e-order-pipeline-flow.js",
    "test:device-limit:e2e": "node scripts/e2e-device-limit-flow.js",
    "test:tenant-isolation:e2e": "node scripts/e2e-tenant-isolation-flow.js",
    "test:tenant-regression:e2e": "node scripts/e2e-tenant-isolation-regression.js",
    "test:e2e:core": "npm run test:critical && npm run test:phone-access:e2e && npm run test:subscription-guard:e2e && npm run test:order-pipeline:e2e",
    "test:e2e:extended": "npm run test:e2e:core && npm run test:tenant-isolation:e2e && npm run test:tenant-regression:e2e && npm run test:device-limit:e2e",
    "test:e2e:full": "node scripts/e2e-full-regression.js",
    "audit:self": "node scripts/nightly-self-audit.js",
    "audit:gate": "node scripts/audit_gate.js",
    "media:backfill": "node scripts/media_assets_backfill.js",
    "media:sanitize": "node scripts/media_assets_sanitize.js",
    "perf:budget": "node scripts/perf_budget_smoke.js",
    "backup:nightly": "./scripts/nightly_backup.sh",
    "maintenance:nightly": "./scripts/nightly_maintenance.sh",
    "recovery:audit": "node scripts/uploads_recovery_audit.js",
    "recovery:restore": "node scripts/uploads_recovery_restore.js",
    "recovery:placeholders": "node scripts/uploads_recovery_apply_placeholders.js",
    "recovery:relink": "node scripts/uploads_recovery_relink_restored.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "firebase-admin": "^13.8.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "otplib": "^12.0.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.20.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0",
    "validator": "^13.15.35",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "nodemon": "^3.0.1"
  },
  "overrides": {
    "path-to-regexp": "0.1.13",
    "socket.io-parser": "4.2.6",
    "protobufjs": "7.5.5"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "express",
    "postgres",
    "api",
    "projectphoenix"
  ],
  "author": "",
  "license": "MIT"
}
