DATABASE_URL=postgresql://projectphoenix:projectphoenix@localhost:5432/projectphoenix
NODE_ENV=development
PORT=3000
JWT_SECRET=your-super-secret-key-min-32-chars-for-security
JWT_SECRET_VERSION=v1
JWT_SECRET_KEYRING=v1:your-super-secret-key-min-32-chars-for-security
APP_DATA_KEY=replace_with_long_random_app_data_key
ADDRESS_DATA_KEY=replace_with_long_random_app_data_key
CREATOR_EMAIL=zerotwo02166@gmail.com
CREATOR_SECRET_HASH=replace_with_sha256_of_creator_secret
APP_MESSAGE_KEY=replace_with_long_random_message_key
APP_MESSAGE_KEY_VERSION=v1
APP_MESSAGE_KEYRING=v1:replace_with_long_random_message_key
CHAT_MEDIA_TOKEN_SECRET=replace_with_long_random_chat_media_key
CHAT_MEDIA_TOKEN_SECRET_VERSION=v1
CHAT_MEDIA_TOKEN_KEYRING=v1:replace_with_long_random_chat_media_key
UPLOADS_TOKEN_SECRET=replace_with_long_random_uploads_key
UPLOADS_TOKEN_SECRET_VERSION=v1
UPLOADS_TOKEN_KEYRING=v1:replace_with_long_random_uploads_key
TRUST_PROXY_HOPS=0
ENFORCE_HTTPS=false
# Disable direct public access to backend port (recommended in production).
# Keep true only if you intentionally expose backend directly without local reverse-proxy.
BLOCK_DIRECT_BACKEND_PUBLIC_ACCESS=true
# Bind backend HTTP listener host.
# In production with local nginx use 127.0.0.1; in containerized/proxy setups use 0.0.0.0.
BIND_HOST=0.0.0.0
# Production example:
# CORS_ORIGINS=https://garphoenix.com,https://www.garphoenix.com
# PUBLIC_BASE_URL=https://garphoenix.com
# API_PUBLIC_BASE_URL=https://garphoenix.com
# SETUP_TOKEN=<long-random-setup-token>
CORS_ORIGINS=
PUBLIC_BASE_URL=
API_PUBLIC_BASE_URL=
AUTH_EMAIL_LINK_BASE=
SETUP_TOKEN=
JSON_BODY_LIMIT=2mb
URLENCODED_BODY_LIMIT=2mb
CHAT_MEDIA_MAX_FILE_SIZE_BYTES=67108864
PRODUCT_IMAGE_MAX_MB=8
MESSAGE_ENCRYPTION_ROTATE_TO_CURRENT=true
TWO_FACTOR_ISSUER=ProjectPhoenix
RATE_LIMIT_DIRECT_SEARCH_MAX=35
RATE_LIMIT_DIRECT_OPEN_MAX=20
RATE_LIMIT_SUPPORT_ASK_MAX=18
RATE_LIMIT_BUG_REPORT_MAX=8
AUTH_MAGIC_LINK_TTL_MINUTES=15
AUTH_MAGIC_LINK_ENABLED=false
AUTH_PASSWORD_RESET_TTL_MINUTES=15
AUTH_REGISTRATION_CODE_TTL_MINUTES=10
AUTH_REGISTRATION_VERIFY_TTL_MINUTES=30

# SMTP / transactional email
# Example:
# RESEND_API_KEY=re_xxxxxxxxx
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=resend
# SMTP_PASSWORD=re_xxxxxxxxx
# SMTP_FROM="Fenix <no-reply@auth.garphoenix.com>"
RESEND_API_KEY=
SMTP_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ===== App update prompt (Phoenix updater) =====
# Example Android values:
# APP_UPDATE_ANDROID_ENABLED=true
# APP_UPDATE_ANDROID_LATEST_VERSION=1.0.1
# APP_UPDATE_ANDROID_LATEST_BUILD=2
# APP_UPDATE_ANDROID_MIN_VERSION=1.0.0
# APP_UPDATE_ANDROID_MIN_BUILD=1
# APP_UPDATE_ANDROID_REQUIRED=false
# APP_UPDATE_ANDROID_DOWNLOAD_URL=https://your-domain.com/downloads/fenix-1.0.1.apk
# APP_UPDATE_ANDROID_DEFAULT_FILE=fenix-1.0.1.apk
# APP_UPDATE_ANDROID_TITLE=Доступно обновление Феникс
# APP_UPDATE_ANDROID_MESSAGE=Исправлены ошибки и улучшена стабильность.
APP_UPDATE_ANDROID_ENABLED=false
APP_UPDATE_ANDROID_LATEST_VERSION=
APP_UPDATE_ANDROID_LATEST_BUILD=
APP_UPDATE_ANDROID_MIN_VERSION=
APP_UPDATE_ANDROID_MIN_BUILD=
APP_UPDATE_ANDROID_REQUIRED=false
APP_UPDATE_ANDROID_DOWNLOAD_URL=
APP_UPDATE_ANDROID_DEFAULT_FILE=fenix-1.0.1.apk
# Web Push for browser/PWA notifications
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:admin@garphoenix.com
APP_UPDATE_ANDROID_TITLE=
APP_UPDATE_ANDROID_MESSAGE=
APK_DOWNLOAD_ANDROID_ONLY=true

