# Локальные переопределения только для этой машины.
# Файл server/.env.local игнорируется git и не влияет на прод.

PORT=3001
BIND_HOST=0.0.0.0
AUTH_ACCESS_TOKEN_TTL=24h
AUTH_SESSION_TTL_DAYS=60

# Адресный поиск для локальной разработки.
# По умолчанию рекомендуем запускать локальный Photon-compatible gateway:
#   cd server && PATH=/opt/homebrew/bin:$PATH npm run address-gateway
# Тогда backend может ходить в него как в self-hosted адресный сервис.
DELIVERY_ADDRESS_PROVIDER=photon
DELIVERY_ADDRESS_SUGGEST_URL=http://127.0.0.1:3011/api
DELIVERY_ADDRESS_REVERSE_URL=http://127.0.0.1:3011/reverse
DELIVERY_ADDRESS_COUNTRY_CODES=ru
DELIVERY_ADDRESS_TIMEOUT_MS=3200
DELIVERY_ADDRESS_RETRY_COUNT=1
DELIVERY_ADDRESS_ALLOW_PUBLIC_FALLBACK=false
ADDRESS_GATEWAY_PORT=3011
ADDRESS_GATEWAY_HOST=127.0.0.1
ADDRESS_GATEWAY_UPSTREAM_SEARCH_URL=https://nominatim.openstreetmap.org/search
ADDRESS_GATEWAY_UPSTREAM_REVERSE_URL=https://nominatim.openstreetmap.org/reverse
ADDRESS_GATEWAY_COUNTRY_CODES=ru
ADDRESS_GATEWAY_TIMEOUT_MS=3200
ADDRESS_GATEWAY_RETRY_COUNT=1
ADDRESS_GATEWAY_CACHE_TTL_MS=300000

# Firebase Admin для native push через FCM/APNs.
# Укажите один из вариантов:
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# FIREBASE_SERVICE_ACCOUNT_BASE64='...'
# FIREBASE_SERVICE_ACCOUNT_PATH='/abs/path/firebase-service-account.json'
# FIREBASE_PROJECT_ID='your-firebase-project-id'

# Android APK updater для локального/dev теста.
# В production источником истины должен быть server/downloads/android-stable.release.json.
# Env-поля ниже нужны только для локального fallback-режима.
# В production обязательно замените dev-ключи реальными ed25519 ключами.
APP_UPDATE_ANDROID_ENABLED=true
APP_UPDATE_ANDROID_LATEST_VERSION=1.0.12
APP_UPDATE_ANDROID_LATEST_BUILD=13
APP_UPDATE_ANDROID_MIN_VERSION=1.0.10
APP_UPDATE_ANDROID_MIN_BUILD=11
APP_UPDATE_ANDROID_REQUIRED=false
APP_UPDATE_ANDROID_DEFAULT_FILE=fenix-1.0.12.apk
APP_UPDATE_ANDROID_CHANNEL=stable
APP_UPDATE_ANDROID_TITLE=Доступно обновление Феникс
APP_UPDATE_ANDROID_MESSAGE=Скачайте новую версию прямо из приложения.
APP_UPDATE_ANDROID_CHANGELOG=Новый APK updater\nВозобновление загрузки\nПроверка файла перед установкой
APP_UPDATE_ALLOWED_HOSTS=127.0.0.1:3001,localhost:3001
APP_UPDATE_MANIFEST_KEY_ID=dev-ed25519
